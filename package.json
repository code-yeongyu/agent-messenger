{
  "name": "agent-messenger",
  "version": "1.6.0",
  "description": "Multi-platform messaging CLI for AI agents (Slack, Discord, Teams)",
  "repository": {
    "type": "git",
    "url": "https://github.com/devxoul/agent-messenger"
  },
  "type": "module",
  "module": "dist/cli.js",
  "main": "dist/cli.js",
  "bin": {
    "agent-messenger": "./src/cli.ts",
    "amsg": "./src/cli.ts",
    "agent-slack": "./src/platforms/slack/cli.ts",
    "agent-discord": "./src/platforms/discord/cli.ts",
    "agent-teams": "./src/platforms/teams/cli.ts",
    "agent-slackbot": "./src/platforms/slackbot/cli.ts",
    "agent-discordbot": "./src/platforms/discordbot/cli.ts"
  },
  "scripts": {
    "build": "tsc && tsc-alias --resolve-full-paths",
    "postbuild": "bun scripts/postbuild.ts",
    "test": "bun test src/",
    "test:e2e": "bun --config=bunfig.e2e.toml test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "dev": "bun --hot ./dist/cli.js",
    "prepublishOnly": "bun run build && bun scripts/prepublish.ts",
    "postpublish": "git checkout package.json"
  },
  "dependencies": {
    "@slack/web-api": "^6.9.0",
    "commander": "^11.1.0",
    "zod": "^3.22.4",
    "classic-level": "^1.3.0",
    "better-sqlite3": "^12.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/better-sqlite3": "^7.6.8",
    "@types/bun": "latest",
    "@types/node": "^20.10.6",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
