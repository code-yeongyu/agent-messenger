{
  "name": "agent-messenger",
  "version": "2.20.2",
  "description": "Multi-platform messaging CLI for AI agents (Slack, Discord, Teams, Webex, Telegram, Telegram Bot, WhatsApp, LINE, Instagram, KakaoTalk, Channel Talk)",
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-messenger/agent-messenger"
  },
  "bin": {
    "agent-channeltalk": "./src/platforms/channeltalk/cli.ts",
    "agent-channeltalkbot": "./src/platforms/channeltalkbot/cli.ts",
    "agent-discord": "./src/platforms/discord/cli.ts",
    "agent-discordbot": "./src/platforms/discordbot/cli.ts",
    "agent-instagram": "./src/platforms/instagram/cli.ts",
    "agent-kakaotalk": "./src/platforms/kakaotalk/cli.ts",
    "agent-line": "./src/platforms/line/cli.ts",
    "agent-messenger": "./src/cli.ts",
    "agent-slack": "./src/platforms/slack/cli.ts",
    "agent-slackbot": "./src/platforms/slackbot/cli.ts",
    "agent-teams": "./src/platforms/teams/cli.ts",
    "agent-telegram": "./src/platforms/telegram/cli.ts",
    "agent-telegrambot": "./src/platforms/telegrambot/cli.ts",
    "agent-webex": "./src/platforms/webex/cli.ts",
    "agent-wechatbot": "./src/platforms/wechatbot/cli.ts",
    "agent-whatsapp": "./src/platforms/whatsapp/cli.ts",
    "agent-whatsappbot": "./src/platforms/whatsappbot/cli.ts",
    "amsg": "./src/cli.ts"
  },
  "type": "module",
  "main": "dist/cli.js",
  "module": "dist/cli.js",
  "typesVersions": {
    "*": {
      "slack": [
        "./src/platforms/slack/index.ts"
      ],
      "slackbot": [
        "./src/platforms/slackbot/index.ts"
      ],
      "discord": [
        "./src/platforms/discord/index.ts"
      ],
      "discordbot": [
        "./src/platforms/discordbot/index.ts"
      ],
      "teams": [
        "./src/platforms/teams/index.ts"
      ],
      "webex": [
        "./src/platforms/webex/index.ts"
      ],
      "whatsapp": [
        "./src/platforms/whatsapp/index.ts"
      ],
      "whatsappbot": [
        "./src/platforms/whatsappbot/index.ts"
      ],
      "line": [
        "./src/platforms/line/index.ts"
      ],
      "wechatbot": [
        "./src/platforms/wechatbot/index.ts"
      ],
      "instagram": [
        "./src/platforms/instagram/index.ts"
      ],
      "kakaotalk": [
        "./src/platforms/kakaotalk/index.ts"
      ],
      "channeltalk": [
        "./src/platforms/channeltalk/index.ts"
      ],
      "channeltalkbot": [
        "./src/platforms/channeltalkbot/index.ts"
      ],
      "telegrambot": [
        "./src/platforms/telegrambot/index.ts"
      ]
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/cli.ts",
      "default": "./src/cli.ts"
    },
    "./slack": {
      "types": "./src/platforms/slack/index.ts",
      "default": "./src/platforms/slack/index.ts"
    },
    "./slackbot": {
      "types": "./src/platforms/slackbot/index.ts",
      "default": "./src/platforms/slackbot/index.ts"
    },
    "./discord": {
      "types": "./src/platforms/discord/index.ts",
      "default": "./src/platforms/discord/index.ts"
    },
    "./discordbot": {
      "types": "./src/platforms/discordbot/index.ts",
      "default": "./src/platforms/discordbot/index.ts"
    },
    "./teams": {
      "types": "./src/platforms/teams/index.ts",
      "default": "./src/platforms/teams/index.ts"
    },
    "./webex": {
      "types": "./src/platforms/webex/index.ts",
      "default": "./src/platforms/webex/index.ts"
    },
    "./whatsapp": {
      "types": "./src/platforms/whatsapp/index.ts",
      "default": "./src/platforms/whatsapp/index.ts"
    },
    "./whatsappbot": {
      "types": "./src/platforms/whatsappbot/index.ts",
      "default": "./src/platforms/whatsappbot/index.ts"
    },
    "./line": {
      "types": "./src/platforms/line/index.ts",
      "default": "./src/platforms/line/index.ts"
    },
    "./wechatbot": {
      "types": "./src/platforms/wechatbot/index.ts",
      "default": "./src/platforms/wechatbot/index.ts"
    },
    "./instagram": {
      "types": "./src/platforms/instagram/index.ts",
      "default": "./src/platforms/instagram/index.ts"
    },
    "./kakaotalk": {
      "types": "./src/platforms/kakaotalk/index.ts",
      "default": "./src/platforms/kakaotalk/index.ts"
    },
    "./channeltalk": {
      "types": "./src/platforms/channeltalk/index.ts",
      "default": "./src/platforms/channeltalk/index.ts"
    },
    "./channeltalkbot": {
      "types": "./src/platforms/channeltalkbot/index.ts",
      "default": "./src/platforms/channeltalkbot/index.ts"
    },
    "./telegrambot": {
      "types": "./src/platforms/telegrambot/index.ts",
      "default": "./src/platforms/telegrambot/index.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias --resolve-full-paths",
    "postbuild": "bun scripts/postbuild.ts",
    "test": "bun test src/",
    "test:e2e": "bun --config=bunfig.e2e.toml test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "dev": "bun --hot ./dist/cli.js",
    "prepublishOnly": "bun run build && bun scripts/prepublish.ts",
    "postpublish": "git checkout package.json"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@slack/web-api": "^6.9.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.0.0",
    "blessed": "^0.1.81",
    "bson": "^7.2.0",
    "classic-level": "^3.0.0",
    "commander": "^11.1.0",
    "crypto-js": "^4.2.0",
    "curve25519-js": "^0.0.4",
    "node-bignumber": "^1.2.2",
    "node-int64": "^0.4.0",
    "node-jose": "^2.2.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "thrift": "^0.20.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/blessed": "^0.1.27",
    "@types/bun": "latest",
    "@types/hapi__boom": "^9.0.1",
    "@types/node": "^20.10.6",
    "@types/node-jose": "^1.1.13",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "koffi": "^2.15.2",
    "prebuilt-tdlib": "0.1008062.2"
  },
  "trustedDependencies": [
    "@whiskeysockets/baileys",
    "better-sqlite3",
    "classic-level",
    "protobufjs"
  ]
}
